<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ORCHESTRA | Master Control Center</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Firebase SDKs -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.0.2/firebase-app.js";
        import { getFirestore, collection, onSnapshot, doc, updateDoc, query, orderBy } from "https://www.gstatic.com/firebasejs/11.0.2/firebase-firestore.js";
        import { getAuth, signInAnonymously, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.0.2/firebase-auth.js";

        // CONFIGURATION
        const firebaseConfig = JSON.parse(typeof __firebase_config !== 'undefined' ? __firebase_config : '{}');
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'brandix-orchestrator';
        
        const app = initializeApp(firebaseConfig);
        const db = getFirestore(app);
        const auth = getAuth(app);

        // STATE
        let tasks = [];
        let selectedTaskId = null;

        // AUTHENTICATION
        onAuthStateChanged(auth, (user) => {
            if (!user) {
                signInAnonymously(auth);
            } else {
                initDataSync();
            }
        });

        // DATA SYNC
        function initDataSync() {
            const tasksRef = collection(db, 'artifacts', appId, 'public', 'data', 'tasks');
            // Rule: Fetch all then sort in JS memory to avoid index requirements
            onSnapshot(tasksRef, (snapshot) => {
                tasks = snapshot.docs.map(doc => ({ id: doc.id, ...doc.data() }));
                renderTaskList();
                if (selectedTaskId) renderDetails(selectedTaskId);
            }, (error) => {
                console.error("Sync Error:", error);
                document.getElementById('status-bar').innerHTML = `<span class="text-red-500">Sync Error: Check Firebase Permissions</span>`;
            });
        }

        // UI RENDERING
        function renderTaskList() {
            const listEl = document.getElementById('task-list');
            listEl.innerHTML = tasks.length === 0 ? '<p class="p-8 text-slate-400 text-center">No Tech Packs received yet...</p>' : '';
            
            tasks.forEach(task => {
                const statusColors = {
                    'pending': 'bg-amber-100 text-amber-700 border-amber-200',
                    'approved': 'bg-green-100 text-green-700 border-green-200',
                    'rejected': 'bg-rose-100 text-rose-700 border-rose-200'
                };

                const div = document.createElement('div');
                div.className = `p-4 mb-3 rounded-xl border cursor-pointer transition-all ${selectedTaskId === task.id ? 'border-indigo-500 bg-indigo-50 shadow-md' : 'border-slate-200 bg-white hover:border-indigo-300'}`;
                div.onclick = () => {
                    selectedTaskId = task.id;
                    renderTaskList();
                    renderDetails(task.id);
                };
                
                div.innerHTML = `
                    <div class="flex justify-between items-start">
                        <div>
                            <h3 class="font-bold text-slate-800">${task.company || 'Unknown Client'}</h3>
                            <p class="text-xs text-slate-500">${task.client}</p>
                        </div>
                        <span class="text-[10px] font-bold uppercase px-2 py-1 rounded border ${statusColors[task.status] || 'bg-slate-100'}">
                            ${task.status}
                        </span>
                    </div>
                `;
                listEl.appendChild(div);
            });
        }

        function renderDetails(id) {
            const task = tasks.find(t => t.id === id);
            const detailEl = document.getElementById('detail-view');
            if (!task) return;

            detailEl.innerHTML = `
                <div class="animate-in fade-in slide-in-from-right-4 duration-300">
                    <div class="flex justify-between items-center mb-6">
                        <h2 class="text-2xl font-black text-indigo-900">${task.company} Details</h2>
                        <p class="text-xs font-bold text-slate-400 uppercase">Received: ${task.received || 'N/A'}</p>
                    </div>

                    <!-- Workflow Progress -->
                    <div class="grid grid-cols-4 gap-2 mb-8">
                        <div class="text-center p-2 rounded-lg bg-green-50 border border-green-200">
                            <i data-lucide="mail" class="mx-auto text-green-600 mb-1" size="16"></i>
                            <p class="text-[9px] font-bold uppercase text-green-700">Email Ingest</p>
                        </div>
                        <div class="text-center p-2 rounded-lg ${task.summary ? 'bg-green-50 border-green-200' : 'bg-slate-100 border-slate-200 opacity-50'}">
                            <i data-lucide="brain" class="mx-auto text-indigo-600 mb-1" size="16"></i>
                            <p class="text-[9px] font-bold uppercase text-indigo-700">AI Decoded</p>
                        </div>
                        <div class="text-center p-2 rounded-lg ${task.status === 'approved' ? 'bg-green-50 border-green-200' : 'bg-amber-50 border-amber-200'}">
                            <i data-lucide="user-check" class="mx-auto text-amber-600 mb-1" size="16"></i>
                            <p class="text-[9px] font-bold uppercase text-amber-700">Review</p>
                        </div>
                        <div class="text-center p-2 rounded-lg ${task.status === 'approved' ? 'bg-green-50 border-green-200 animate-pulse' : 'bg-slate-100 border-slate-200 opacity-50'}">
                            <i data-lucide="send" class="mx-auto text-green-600 mb-1" size="16"></i>
                            <p class="text-[9px] font-bold uppercase text-green-700">Dispatch</p>
                        </div>
                    </div>

                    <div class="grid grid-cols-2 gap-6 mb-8">
                        <div class="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm">
                            <h4 class="text-[10px] font-black text-indigo-500 uppercase tracking-widest mb-3">Extracted Content</h4>
                            <p class="text-sm font-medium text-slate-700 leading-relaxed mb-4">${task.summary || 'AI still processing...'}</p>
                            <div class="flex flex-wrap gap-2">
                                ${task.dates ? task.dates.split(',').map(d => `<span class="bg-slate-100 px-2 py-1 rounded text-[10px] font-bold">${d.trim()}</span>`).join('') : ''}
                            </div>
                        </div>
                        
                        <div class="bg-indigo-900 text-white p-5 rounded-2xl shadow-lg relative overflow-hidden">
                            <h4 class="text-[10px] font-black text-indigo-300 uppercase tracking-widest mb-4">Routing Setup</h4>
                            <div class="space-y-3">
                                <div class="flex items-center gap-3">
                                    <div class="w-2 h-2 rounded-full bg-cyan-400"></div>
                                    <p class="text-xs font-bold opacity-80">Sourcing: sourcing@factory.com</p>
                                </div>
                                <div class="flex items-center gap-3">
                                    <div class="w-2 h-2 rounded-full bg-cyan-400"></div>
                                    <p class="text-xs font-bold opacity-80">Patterns: patterns@factory.com</p>
                                </div>
                                <div class="flex items-center gap-3">
                                    <div class="w-2 h-2 rounded-full bg-cyan-400"></div>
                                    <p class="text-xs font-bold opacity-80">Production: floor@factory.com</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    ${task.status === 'pending' ? `
                    <div class="flex gap-4">
                        <button onclick="updateStatus('${task.id}', 'rejected')" class="flex-1 py-4 border border-rose-200 text-rose-600 font-bold rounded-xl hover:bg-rose-50 transition-all">
                            REJECT / REQUEST CHANGES
                        </button>
                        <button onclick="updateStatus('${task.id}', 'approved')" class="flex-[2] py-4 bg-indigo-600 text-white font-black rounded-xl hover:bg-indigo-700 shadow-xl shadow-indigo-200 transition-all flex items-center justify-center gap-2">
                            APPROVE & SEND ALL MAILS <i data-lucide="check-circle" size="20"></i>
                        </button>
                    </div>
                    ` : `
                    <div class="bg-green-600 p-6 rounded-2xl text-white flex items-center justify-between shadow-xl">
                        <div>
                            <p class="text-lg font-black uppercase">Dispatched Successfully</p>
                            <p class="text-xs opacity-80">Confirmation sent to client and all factory departments.</p>
                        </div>
                        <i data-lucide="shield-check" size="48" class="opacity-20"></i>
                    </div>
                    `}
                </div>
            `;
            lucide.createIcons();
        }

        window.updateStatus = async (id, status) => {
            const ref = doc(db, 'artifacts', appId, 'public', 'data', 'tasks', id);
            await updateDoc(ref, { 
                status: status,
                approvedAt: new Date().toISOString()
            });
        };

        window.onload = () => lucide.createIcons();
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap');
        body { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900">

    <!-- Navbar -->
    <nav class="bg-white border-b border-slate-200 p-4 sticky top-0 z-50 shadow-sm">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-3">
                <div class="bg-indigo-600 p-2 rounded-lg text-white">
                    <i data-lucide="layers"></i>
                </div>
                <div>
                    <h1 class="font-extrabold text-xl tracking-tighter">ORCHESTRA</h1>
                    <p id="status-bar" class="text-[9px] font-black uppercase text-indigo-400 tracking-widest">Live Factory Feed Active</p>
                </div>
            </div>
            <div class="flex items-center gap-4 text-sm font-bold">
                <span class="text-slate-400">Merchandiser Console</span>
                <div class="w-8 h-8 bg-slate-100 rounded-full border border-slate-200 flex items-center justify-center text-indigo-600">YM</div>
            </div>
        </div>
    </nav>

    <div class="max-w-7xl mx-auto grid grid-cols-12 gap-8 p-8">
        
        <!-- Left Sidebar: Submission Feed -->
        <aside class="col-span-12 lg:col-span-4">
            <div class="flex items-center gap-2 mb-6">
                <i data-lucide="inbox" class="text-indigo-600" size="20"></i>
                <h2 class="font-black text-sm uppercase tracking-widest text-slate-500">Incoming Queue</h2>
            </div>
            <div id="task-list" class="max-h-[70vh] overflow-y-auto pr-2">
                <!-- Data will load here -->
                <div class="animate-pulse flex flex-col gap-4">
                    <div class="h-20 bg-slate-200 rounded-xl"></div>
                    <div class="h-20 bg-slate-200 rounded-xl"></div>
                </div>
            </div>
        </aside>

        <!-- Right: Master Data View -->
        <section id="detail-view" class="col-span-12 lg:col-span-8 bg-white/50 border border-dashed border-slate-300 rounded-[2rem] p-12 flex items-center justify-center min-h-[60vh]">
            <div class="text-center">
                <div class="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mx-auto mb-6 text-slate-300">
                    <i data-lucide="mouse-pointer-2" size="40"></i>
                </div>
                <h3 class="text-xl font-bold text-slate-400">Select a submission to inspect extraction</h3>
                <p class="text-sm text-slate-300 max-w-xs mx-auto mt-2">All BOM, measurements and trim data will appear here once selected.</p>
            </div>
        </section>

    </div>

</body>
</html>
